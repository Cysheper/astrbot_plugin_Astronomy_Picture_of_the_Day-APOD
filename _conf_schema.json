{
    "token": {
        "description": "NASA API Token",
        "hint": "访问 NASA APOD API 所需的密钥，可以在 https://api.nasa.gov/ 申请",
        "type": "string"
    },
    "image": {
        "description": "是否发送图片",
        "hint": "NASA每日一图的标志性内容，建议开启",
        "type": "bool",
        "default": true
    },
    "explanation": {
        "description": "图片说明",
        "type": "object",
        "items": {
            "is_show": {
                "hint": "官方说明通常比较长，包含丰富的科学信息",
                "description": "是否发送NASA官方的图片说明",
                "type": "bool",
                "default": true
            },
            "is_translate": {
                "hint": "原文一般是英文",
                "description": "是否翻译说明为简体中文",
                "type": "bool",
                "default": true
            }
        }
    },
    "title": {
        "description": "标题配置",
        "type": "object",
        "items": {
            "is_show": {
                "description": "是否发送标题",
                "type": "bool",
                "default": true
            },
            "is_translate": {
                "description": "是否翻译标题",
                "type": "bool",
                "default": true
            }
        }
    },
    "provider": {
        "hint": "如果启用了翻译功能但未配置提供商，将无法进行翻译并可能导致错误日志",
        "description": "翻译所使用的LLM提供商",
        "_special": "select_provider",
        "type": "string"
    },
    "date": {
        "description": "日期配置",
        "type": "object",
        "items": {
            "is_show": {
                "description": "是否发送日期",
                "type": "bool",
                "default": true
            }
        }
    },
    "is_divided": {
        "description": "是否分开发送图片和文本内容",
        "type": "bool",
        "default": true
    },
    "timeout": {
        "description": "请求 APOD 数据的超时时间，单位为秒",
        "type": "int",
        "default": 120
    },
    "retry_count": {
        "description": "遇到 NASA API 临时错误时的重试次数",
        "type": "int",
        "default": 2
    }
}
